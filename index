  let currentQuestions = [];
  let currentIndex = 0;
  let solvedIndex = -1;
  let userAnswers = {};
  let currentSetKey = "";
  let stats = { correct: 0, wrong: 0 };
  let wrongQuestionsMode = false;

  function storagePrefix() {
    return "exam_" + CURRENT_SUBJECT.replace(/\s+/g, "_") + "_";
  }

  function setStateKey(index) {
    return storagePrefix() + "state_set_" + index;
  }

  function wrongQuestionsKey() {
    return storagePrefix() + "wrong_questions_pool";
  }

  function getWrongQuestionsPool() {
    return JSON.parse(localStorage.getItem(wrongQuestionsKey()) || "[]");
  }

  function saveWrongQuestionsPool(pool) {
    localStorage.setItem(wrongQuestionsKey(), JSON.stringify(pool));
  }

  function addWrongQuestionToPool(question) {
    const pool = getWrongQuestionsPool();

    const exists = pool.some(item =>
      item.q === question.q &&
      JSON.stringify(item.o) === JSON.stringify(question.o)
    );

    if (!exists) {
      pool.push({
        q: question.q,
        o: [...question.o],
        c: question.c,
        e: question.e || ""
      });
      saveWrongQuestionsPool(pool);
    }
  }

  function normalizeQuestion(q, originalIndex) {
    return {
      id: q.id || ("q_" + originalIndex + "_" + Math.random().toString(36).slice(2, 8)),
      originalNo: originalIndex + 1,
      q: q.q,
      o: [...q.o],
      c: q.c,
      e: q.e || "",
      isRetry: q.isRetry || false,
      retryFrom: q.retryFrom || null,
      retryCount: q.retryCount || 0,
      answeredCorrectly: q.answeredCorrectly || false
    };
  }

  function initMenu() {
    const menuGrid = document.getElementById("menuGrid");
    menuGrid.innerHTML = "";

    const totalSets = Math.ceil(questions.length / QUESTIONS_PER_SET);

    let setsPerButton = 1;
    let buttonCount = totalSets;

    if (buttonCount > 10) {
      setsPerButton = 2;
      buttonCount = Math.ceil(totalSets / setsPerButton);
    }

    buttonCount = Math.min(buttonCount, 10);

    for (let i = 0; i < buttonCount; i++) {
      const startSetNo = i * setsPerButton + 1;
      const endSetNo = Math.min(startSetNo + setsPerButton - 1, totalSets);

      const start = (startSetNo - 1) * QUESTIONS_PER_SET;
      const end = Math.min(endSetNo * QUESTIONS_PER_SET, questions.length);

      if (start >= questions.length) continue;

      const key = setStateKey(i);

      const saved = JSON.parse(localStorage.getItem(key) || "null");
      const solved = saved ? Object.keys(saved.userAnswers || {}).length : 0;
      const correct = saved?.stats?.correct || 0;
      const wrong = saved?.stats?.wrong || 0;

      const totalCurrent = saved?.currentQuestions?.length || (end - start);
      const isCompleted = saved ? (solved >= totalCurrent && totalCurrent > 0) : false;

      const label = startSetNo === endSetNo
        ? `Deneme-${startSetNo}`
        : `Deneme-${startSetNo}-${endSetNo}`;

      const btn = document.createElement("button");
      btn.className = `menu-btn ${isCompleted ? "locked" : ""}`;
      btn.innerHTML = `
        <strong>${label}</strong><br>
        <small>${end - start} Soru | Çözülen ${solved} (Doğru ${correct} Yanlış ${wrong})</small>
      `;

      if (!isCompleted) {
        btn.onclick = () => startSet(i, key, start, end);
      }

      menuGrid.appendChild(btn);
    }

    const wrongPool = getWrongQuestionsPool();

    if (wrongPool.length > 0) {
      const wrongBtn = document.createElement("button");
      wrongBtn.className = "wrong-menu-btn";
      wrongBtn.innerHTML = `
        <strong>Yanlış Yapılan Sorular</strong><br>
        <small>${wrongPool.length} Soru | Yeniden çöz</small>
      `;
      wrongBtn.onclick = openWrongQuestions;
      menuGrid.appendChild(wrongBtn);
    }
  }

  function openWrongQuestions() {
    const pool = getWrongQuestionsPool();
    if (!pool.length) return;

    wrongQuestionsMode = true;
    currentSetKey = storagePrefix() + "wrong_questions_state";

    const saved = JSON.parse(localStorage.getItem(currentSetKey) || "null");

    if (saved) {
      currentQuestions = saved.currentQuestions;
      currentIndex = saved.currentIndex;
      solvedIndex = saved.solvedIndex;
      userAnswers = saved.userAnswers || {};
      stats = saved.stats || { correct: 0, wrong: 0 };
    } else {
      currentQuestions = pool.map((q, i) => ({
        id: "wrong_" + i + "_" + Math.random().toString(36).slice(2, 8),
        originalNo: i + 1,
        q: q.q,
        o: [...q.o],
        c: q.c,
        e: q.e || "",
        isRetry: false,
        retryFrom: null,
        retryCount: 0,
        answeredCorrectly: false
      }));

      currentIndex = 0;
      solvedIndex = -1;
      userAnswers = {};
      stats = { correct: 0, wrong: 0 };
      saveState();
    }

    document.getElementById("menuContainer").style.display = "none";
    document.getElementById("quizContainer").style.display = "block";
    document.getElementById("headerSubject").textContent = "Yanlış Yapılan Sorular";
    loadQuestion();
    window.scrollTo(0, 0);
  }

  function startSet(idx, key, start, end) {
    wrongQuestionsMode = false;
    currentSetKey = key;

    const saved = JSON.parse(localStorage.getItem(key) || "null");

    if (saved) {
      currentQuestions = saved.currentQuestions;
      currentIndex = saved.currentIndex;
      solvedIndex = saved.solvedIndex;
      userAnswers = saved.userAnswers || {};
      stats = saved.stats || { correct: 0, wrong: 0 };
    } else {
      currentQuestions = questions.slice(start, end).map((q, i) => normalizeQuestion(q, start + i));
      currentIndex = 0;
      solvedIndex = -1;
      userAnswers = {};
      stats = { correct: 0, wrong: 0 };
      saveState();
    }

    document.getElementById("menuContainer").style.display = "none";
    document.getElementById("quizContainer").style.display = "block";
    document.getElementById("headerSubject").textContent = BASE_SUBJECT;
    loadQuestion();
    window.scrollTo(0, 0);
  }

  function getQuestionTitle(q) {
    return `Soru-${q.originalNo}: ${q.q}`;
  }

  function loadQuestion() {
    const q = currentQuestions[currentIndex];
    const progress = ((currentIndex + 1) / currentQuestions.length) * 100;

    document.getElementById("progressBar").style.width = progress + "%";
    document.getElementById("footerLeft").textContent = `Kalan: ${Math.max(currentQuestions.length - (currentIndex + 1), 0)}`;
    document.getElementById("footerRight").textContent = `${currentIndex + 1} / ${currentQuestions.length}`;
    document.getElementById("questionText").textContent = getQuestionTitle(q);

    const retryBadge = document.getElementById("retryBadge");
    retryBadge.style.display = q.isRetry ? "block" : "none";

    const optArea = document.getElementById("optionsArea");
    const expArea = document.getElementById("explanationArea");
    optArea.innerHTML = "";
    expArea.style.display = "none";
    expArea.innerHTML = "";

    const letters = ["A", "B", "C", "D", "E"];

    q.o.forEach((opt, idx) => {
      const btn = document.createElement("button");
      btn.className = "option-btn";
      btn.innerHTML = `<strong>${letters[idx]})</strong> ${opt}`;

      if (currentIndex <= solvedIndex) {
        btn.disabled = true;
        const userChoice = userAnswers[currentIndex];

        if (idx === userChoice) {
          if (userChoice === q.c) {
            btn.classList.add("correct");
            btn.innerHTML += ` <span class="tick show">✔</span>`;
          } else {
            btn.classList.add("wrong");
          }
        }

        if (wrongQuestionsMode) {
          if (idx === q.c) {
            btn.classList.add("correct");
            btn.innerHTML += ` <span class="tick show">✔</span>`;
          }
          expArea.innerHTML = `<strong>Açıklama:</strong> ${q.e}`;
          expArea.style.display = "block";
        } else {
          if (userChoice === q.c) {
            expArea.innerHTML = `<strong>Açıklama:</strong> ${q.e}`;
            expArea.style.display = "block";
          } else if (q.isRetry) {
            if (idx === q.c) {
              btn.classList.add("correct");
              btn.innerHTML += ` <span class="tick show">✔</span>`;
            }
            expArea.innerHTML = `<strong>Açıklama:</strong> ${q.e}`;
            expArea.style.display = "block";
          }
        }
      } else {
        btn.onclick = () => selectOption(idx);
      }

      optArea.appendChild(btn);
    });

    document.getElementById("prevBtn").style.visibility = currentIndex > 0 ? "visible" : "hidden";
    document.getElementById("nextBtn").style.visibility = currentIndex <= solvedIndex ? "visible" : "hidden";
  }

  function selectOption(idx) {
    const q = currentQuestions[currentIndex];
    const isCorrect = idx === q.c;

    userAnswers[currentIndex] = idx;
    solvedIndex = Math.max(solvedIndex, currentIndex);

    if (isCorrect) {
      stats.correct++;
      q.answeredCorrectly = true;
    } else {
      stats.wrong++;

      if (wrongQuestionsMode) {
        // Yanlış Yapılan Sorular modunda soru yeniden eklenmez.
      } else {
        addWrongQuestionToPool(q);

        if (!q.isRetry) {
          const retryQuestion = {
            ...q,
            isRetry: true,
            retryFrom: q.originalNo,
            retryCount: 1
          };

          const insertIndex = Math.min(currentIndex + 5, currentQuestions.length);
          currentQuestions.splice(insertIndex, 0, retryQuestion);
        }
      }
    }

    saveState();
    loadQuestion();
  }

  function saveState() {
    localStorage.setItem(currentSetKey, JSON.stringify({
      currentQuestions,
      currentIndex,
      solvedIndex,
      userAnswers,
      stats
    }));
  }

  function goForward() {
    if (currentIndex < solvedIndex) {
      currentIndex = solvedIndex + 1;
    } else if (currentIndex < currentQuestions.length - 1) {
      currentIndex++;
    } else {
      return showMenu();
    }

    saveState();
    loadQuestion();
    window.scrollTo(0, 0);
  }

  function goBack() {
    if (currentIndex > 0) {
      currentIndex--;
      saveState();
      loadQuestion();
      window.scrollTo(0, 0);
    }
  }

  function showMenu() {
    wrongQuestionsMode = false;
    document.getElementById("headerSubject").textContent = BASE_SUBJECT;
    document.getElementById("quizContainer").style.display = "none";
    document.getElementById("menuContainer").style.display = "block";
    initMenu();
    window.scrollTo(0, 0);
  }

  function clearAllStatistics() {
    if (confirm("Tüm veriler sıfırlansın mı?")) {
      Object.keys(localStorage).forEach(k => {
        if (k.startsWith(storagePrefix())) localStorage.removeItem(k);
      });
      initMenu();
    }
  }

  function resetCurrentSet() {
    if (confirm("Bu deneme sıfırlansın mı?")) {
      localStorage.removeItem(currentSetKey);
      showMenu();
    }
  }

  initMenu();
</script>

<script>
function shuffleAllQuestions() {
  if (!confirm("Tüm sorular ve şıkları karıştırılsın mı?")) return;

  // Şıkları karıştır (doğruyu koru)
  questions.forEach(q => {
    const correct = q.o[q.c];

    for (let i = q.o.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [q.o[i], q.o[j]] = [q.o[j], q.o[i]];
    }

    q.c = q.o.findIndex(x => x === correct);
  });

  // Soruları karıştır
  for (let i = questions.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [questions[i], questions[j]] = [questions[j], questions[i]];
  }

  // localStorage temizle (mevcut sistemle uyumlu)
  if (typeof storagePrefix === "function") {
    Object.keys(localStorage).forEach(k => {
      if (k.startsWith(storagePrefix())) localStorage.removeItem(k);
    });
  }

  alert("Sorular karıştırıldı!");

  if (typeof initMenu === "function") initMenu();
}
</script>

